<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Happy Birthday Mela Mellisa</title>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.5.1/dist/confetti.browser.min.js"></script>
    <style>
        :root {
            --pink: #ffb6c1; --peach: #ffdab9; --gold: #ffd700; --dark: #4a4a4a;
        }
        body {
            margin: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, var(--pink), var(--peach));
            color: var(--dark); overflow-x: hidden; text-align: center;
        }
        /* Floating Petals Animation */
        .petal {
            position: fixed; background: #fff0f5; border-radius: 150% 0 150% 0;
            opacity: 0.7; z-index: -1; animation: float 10s infinite linear;
        }
        @keyframes float {
            0% { transform: translateY(-10vh) rotate(0); }
            100% { transform: translateY(110vh) rotate(360deg); }
        }
        header { height: 100vh; display: flex; flex-direction: column; justify-content: center; align-items: center; }
        h1 { font-size: 3rem; color: white; text-shadow: 0 0 15px var(--gold); animation: glow 2s ease-in-out infinite alternate; padding: 0 20px; }
        @keyframes glow { from { text-shadow: 0 0 10px #fff; } to { text-shadow: 0 0 30px var(--gold); } }
        
        .card-container { padding: 20px; display: flex; flex-wrap: wrap; justify-content: center; gap: 20px; margin-bottom: 50px; }
        .card { 
            background: rgba(255, 255, 255, 0.9); padding: 20px; border-radius: 15px;
            width: 280px; cursor: pointer; transition: 0.3s; box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
        .card:hover { transform: translateY(-10px); background: #fff; }
        .hidden-text { display: none; margin-top: 15px; font-style: italic; color: #d4a017; line-height: 1.5; }
        
        #countdown { font-size: 1.2rem; margin: 30px 0; background: rgba(255,255,255,0.8); display: inline-block; padding: 10px 25px; border-radius: 50px; border: 2px solid white; }
        footer { padding: 60px 20px; font-size: 1.1rem; color: white; background: rgba(0,0,0,0.05); }
    </style>
</head>
<body>

    <header>
        <h1>Happy Birthday, <br>Mela Mellisa! 🌸</h1>
        <p>A special page for a special person.</p>
        <div id="countdown">Calculating time...</div>
    </header>

    <div class="card-container">
        <div class="card" onclick="reveal(this)">
            <h3>💌 A Special Note</h3>
            <p class="hidden-text">"Selamat ulang tahun sayang, Mela Mellisa! Terima kasih sudah selalu jadi versi terbaik dari diri kamu. Semoga hari ini seindah senyumanmu!"</p>
        </div>
        <div class="card" onclick="reveal(this)">
            <h3>✨ My Wish #1</h3>
            <p class="hidden-text">Semoga di usia baru ini, Mela selalu dikelilingi kebahagiaan dan orang-orang yang tulus sayang sama kamu.</p>
        </div>
        <div class="card" onclick="reveal(this)">
            <h3>🌈 My Wish #2</h3>
            <p class="hidden-text">Semoga semua mimpi dan rencana besar kamu dimudahkan jalannya. Kamu pasti bisa!</p>
        </div>
    </div>

    <footer>
        <p>Dibuat dengan sepenuh hati ❤️<br>untuk Mela Mellisa</p>
    </footer>

    <script>
        // Confetti on load
        window.onload = () => {
            confetti({ 
                particleCount: 150, 
                spread: 70, 
                origin: { y: 0.6 }, 
                colors: ['#ffb6c1', '#ffd700', '#ffdab9'] 
            });
            createPetals();
        };

        function reveal(el) {
            const txt = el.querySelector('.hidden-text');
            txt.style.display = txt.style.display === 'block' ? 'none' : 'block';
        }

        function createPetals() {
            for(let i=0; i<25; i++) {
                let petal = document.createElement('div');
                petal.className = 'petal';
                petal.style.left = Math.random() * 100 + 'vw';
                petal.style.width = petal.style.height = Math.random() * 15 + 10 + 'px';
                petal.style.animationDuration = Math.random() * 5 + 7 + 's';
                petal.style.animationDelay = Math.random() * 5 + 's';
                document.body.appendChild(petal);
            }
        }

        // Timer Countdown (Set ke akhir hari ulang tahun)
        const targetDate = new Date(); 
        targetDate.setHours(23, 59, 59, 999); 

        setInterval(() => {
            const now = new Date().getTime();
            const diff = targetDate - now;
            
            if (diff < 0) {
                document.getElementById('countdown').innerHTML = "Hope your birthday was amazing! ✨";
                return;
            }

            const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
            const secs = Math.floor((diff % (1000 * 60)) / 1000);
            document.getElementById('countdown').innerHTML = `Birthday ends in: ${hours}h ${mins}m ${secs}s`;
        }, 1000);
    </script>
</body>
</html>
